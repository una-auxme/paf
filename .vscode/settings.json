{
  "githubIssues.issueBranchTitle": "${issueNumber}-${sanitizedIssueTitle}",
  "githubIssues.queries": [
    {
      "label": "My Issues",
      "query": "default"
    },
    {
      "label": "Created Issues",
      "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
    },
    {
      "label": "Assigned Issues",
      "query": "assignee:${user} state:open repo:${owner}/${repository} sort:created-desc"
    },
    {
      "label": "All Issues",
      "query": "state:open repo:${owner}/${repository} sort:created-desc"
    }
  ],
  "ltex.language": "en-US",
  "workbench.iconTheme": "vscode-icons",
  "editor.formatOnSave": true,
  "markdown.extension.toc.levels": "2..6",
  "markdown.extension.toc.updateOnSave": true,
  "markdown.extension.toc.unorderedList.marker": "-",
  "markdown.extension.theming.decoration.renderTrailingSpace": true,
  "cmake.ignoreCMakeListsMissing": true,
  "containers.composeBuild": true,
  "containers.composeDetached": false,
  "task.allowAutomaticTasks": "on",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "ROS2.distro": "jazzy",
  "python.autoComplete.extraPaths": [
    "/internal_workspace/carla_ros2_ws/install/rqt_carla_control/lib/python3.12/site-packages",
