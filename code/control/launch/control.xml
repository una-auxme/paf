<launch>
    <arg name="role_name" default="hero" />
    <arg name="control_loop_rate" default="0.05" />

    <node pkg="control" exec="velocity_controller" name="velocity_controller">
        <param name="control_loop_rate" value="$(var control_loop_rate)" />
        <param name="role_name" value="$(var role_name)" />
        <param from="$(find-pkg-share control)/config/control.yaml"/>
    </node>

    <node pkg="control" exec="pure_pursuit_controller" name="pure_pursuit_controller">
        <param name="control_loop_rate" value="$(var control_loop_rate)" />
        <param name="role_name" value="$(var role_name)" />
        <param from="$(find-pkg-share control)/config/control.yaml"/>
    </node>

    <node pkg="control" exec="vehicle_controller" name="vehicle_controller">
        <param name="control_loop_rate" value="$(var control_loop_rate)" />
        <param name="role_name" value="$(var role_name)" />
        <param from="$(find-pkg-share control)/config/control.yaml"/>
    </node>

</launch>
